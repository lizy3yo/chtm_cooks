# Database Configuration
MONGODB_URI=mongodb://localhost:27017/chtm_cooks

# JWT Secrets (Generate secure random strings for production)
JWT_ACCESS_SECRET=your-access-secret-here-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-here-change-in-production

# Email Configuration (Required for password reset and email verification)
# For Gmail: use smtp.gmail.com with port 587
# Make sure to enable "Less secure app access" or use App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password-or-app-password
EMAIL_FROM="CHTM Cooks" <noreply@chtmcooks.com>

# Application URL (Used in email links)
# Development: http://localhost:5173
# Production: https://yourdomain.com
APP_URL=http://localhost:5173

# Redis Configuration (Optional - for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# Security
BCRYPT_ROUNDS=12

# Public Base URL (for client-side usage)
PUBLIC_BASE_URL=http://localhost:5173

# AI Assistant (Primary: Google AI Studio Gemini, Fallback: Bytez)
# Google AI Studio key: https://aistudio.google.com
GEMINI_API_KEY=your-google-ai-studio-api-key
# Optional alias supported by the server (use one of GEMINI_API_KEY or GOOGLE_API_KEY)
GOOGLE_API_KEY=
# Optional Gemini model override
GOOGLE_AI_MODEL=gemini-3-flash-preview
# Optional Google request timeout in ms (minimum 5000)
GOOGLE_AI_TIMEOUT_MS=25000

# Bytez fallback key (optional but recommended)
# Get your key at: https://bytez.com
BYTEZ_API_KEY=your-bytez-api-key-here

# Storage Configuration
# Options: 'cloudinary' or 'local'
STORAGE_PROVIDER=cloudinary

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=inventory
